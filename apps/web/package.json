{
  "name": "@vital-ice/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/next-dev.cjs --turbo --hostname 0.0.0.0 --startPort 3000",
    "build": "next build --webpack && node scripts/ensure-next-lock.cjs",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "analyze": "ANALYZE=true next build",
    "export": "next export",
    "test": "node scripts/assert-dynamic-ssr-compliance.cjs && jest",
    "test:compliance": "node scripts/assert-dynamic-ssr-compliance.cjs",
    "test:analytics": "NEXT_PUBLIC_ANALYTICS_ENABLED=true PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test tests/analytics.spec.ts",
    "pw:install": "playwright install chromium",
    "test:ssr-hydration": "playwright test tests/ssr-hydration.spec.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "ssr:audit": "node scripts/ssr-audit.mjs",
    "ssr:build-check": "node scripts/assert-route-classification.cjs"
  },
  "dependencies": {
    "@portabletext/to-html": "^2.0.0",
    "@sanity/image-url": "^1.2.0",
    "@sentry/nextjs": "^10.29.0",
    "@sentry/profiling-node": "^10.29.0",
    "@types/nodemailer": "^6.4.17",
    "@vercel/analytics": "^1.5.0",
    "@vital-ice/config": "workspace:*",
    "@vital-ice/transactional": "workspace:*",
    "@vital-ice/ui": "workspace:*",
    "framer-motion": "^12.18.1",
    "import-in-the-middle": "^3.0.0",
    "lenis": "^1.3.4",
    "next": "^16.0.8",
    "next-sanity": "^11.6.7",
    "nodemailer": "^7.0.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.0",
    "require-in-the-middle": "^8.0.1",
    "resolve": "^1.22.8",
    "sanitize-html": "^2.17.1",
    "styled-components": "^6.1.19",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.0.8",
    "@playwright/test": "^1.58.2",
    "@swc-node/register": "^1.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "@vital-ice/test-utils": "workspace:*",
    "critters": "^0.0.20",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
