# Site identity (Beringia defaults are baked into @vital-ice/config when unset)
# NEXT_PUBLIC_SITE_URL=https://beringia-marine.com
# NEXT_PUBLIC_SITE_NAME=Beringia Marine
# NEXT_PUBLIC_LEGAL_NAME=Beringia Marine Technologies
# NEXT_PUBLIC_SITE_DESCRIPTION=
# NEXT_PUBLIC_SEO_DEFAULT_TITLE=
# NEXT_PUBLIC_OG_FALLBACK_DESCRIPTION=
# NEXT_PUBLIC_SEO_KEYWORDS=
# NEXT_PUBLIC_THEME_COLOR=#052533

# Contact (canonical — see packages/config/src/shell.ts CONTACT_DATA_QUALITY_NOTE)
# NEXT_PUBLIC_CONTACT_EMAIL=info@beringia-marine.com
# NEXT_PUBLIC_CONTACT_PHONE=+18053161417

# Contact form delivery (no Resend required). Pick ONE:
# — Recommended free: Web3Forms https://web3forms.com — create a form, verify inbox, paste access key (browser submit; add localhost in dashboard for dev).
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
# — Or Gmail SMTP (used by POST /api/contact if Web3 public key is unset): App Password → EMAIL_USER / EMAIL_PASSWORD.
# Optional override for who receives SMTP mail (defaults to business email from config):
# CONTACT_INBOX_EMAIL=info@beringia-marine.com
# EMAIL_USER=
# EMAIL_PASSWORD=

# Assets — TODO: set when production OG image, logo, and favicon set exist under public/
# NEXT_PUBLIC_DEFAULT_OG_IMAGE_PATH=/globe.svg
# NEXT_PUBLIC_LOGO_PATH=/logo-emblem-bw.svg

# Social
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/beringia-marine

# Search Console (fallback exists in config when unset)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Dev: floating control to A/B Domitian+Inter vs Bebas+Montserrat (also on in NODE_ENV=development)
# NEXT_PUBLIC_FONT_PRESET_TOGGLE=1
